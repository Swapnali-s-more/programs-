<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/cs s/bootstrap.min.css" 
rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-4">
<div class="card p-4 shadow">
<h3 class="text-center">Login</h3>
<form onsubmit="return login()">
<div class="mb-3">
<label>Username</label>
<input type="text" id="user" class="form-control" required>
</div>
<div class="mb-3">
<label>Password</label>
<input type="password" id="pass" class="form-control" required>
</div>
<button class="btn btn-warning w-100">Login</button>
</form>
</div>
</div>
</div>
</div>
<script>
function login(){
let username = document.getElementById("user").value;
let password = document.getElementById("pass").value;
if(username=="admin" && password=="1234")
{
window.location="home.html";
}
else
{
alert("Invalid Login");
}
return false;
}
</script>
</body>
</html>